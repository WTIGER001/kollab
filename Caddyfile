{$DOMAIN:localhost} {
    # Proxy API and WebSocket connections to the Go backend container
    # (Caddy automatically handles WebSocket connection upgrading out of the box)
    handle /api/* {
        reverse_proxy go-backend:8080
    }

    # Serve the React frontend static build for all other routes
    handle {
        root * /srv/dist
        try_files {path} /index.html
        file_server
    }
}
